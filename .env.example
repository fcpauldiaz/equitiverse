# Database — local dev uses file:local.db; production uses Turso
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# App URL (used for auth cookies, invite links, email CTAs)
BETTER_AUTH_URL=http://localhost:3000

# Market data — free key from https://finnhub.io
FINNHUB_API_KEY=

# Email — free tier from https://resend.com
RESEND_API_KEY=
EMAIL_FROM=EquitiVerse <onboarding@resend.dev>

# Cron route protection
CRON_SECRET=dev-cron-secret

# Seed script defaults (optional)
ADMIN_EMAIL=admin@edgebyrs.com
ADMIN_PASSWORD=change-me-now
